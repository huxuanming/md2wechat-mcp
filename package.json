{
  "name": "md2wechat-mcp",
  "version": "0.1.0",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test:watch": "vitest",
    "build:check": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "chmod +x dist/server.js dist/cli.js dist/browser.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Markdown to WeChat HTML MCP server (Node.js)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "md2wechat-mcp": "dist/server.js",
    "md2wechat": "dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
